rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Staff at the same facility as the mother can read PPD questionnaire audio (TSA).
    function staffCanReadPatientPpdAudio(patientUserId) {
      return firestore.exists(/databases/(default)/documents/staff/$(request.auth.uid)) &&
        firestore.exists(/databases/(default)/documents/users/$(patientUserId)) &&
        firestore.get(/databases/(default)/documents/staff/$(request.auth.uid)).data.facilityId ==
        firestore.get(/databases/(default)/documents/users/$(patientUserId)).data.linkedFacilityId;
    }

    // Per-question EPDS audio lives under users/{uid}/ppd/...
    match /users/{userId}/ppd/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        staffCanReadPatientPpdAudio(userId)
      );
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read/write their own files (profile photo, meals, etc.)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
